    "@uiw/codemirror-theme-material": "^4.24.2",
    "@uiw/react-codemirror": "^4.24.2",
    "bcryptjs": "^3.0.3",
    "detect-browser": "^5.3.0",
    "fractional-indexing": "^3.2.0",
    "hono": "4.12.7",
    "js-yaml": "^4.1.1",
    "mobx": "^6.15.0",
    "mobx-react-lite": "^4.1.1",
    "mobx-utils": "^6.1.1",
    "notifyjs": "^3.0.0",
